from ultralytics import YOLO
import os
from google.colab import drive
drive.mount('/content/drive')
%cd /content/drive/MyDrive/Project-Augmentarium
model = YOLO("yolov8n.pt")
model.train(
    data="dataset/data.yaml",
    epochs=100,
    imgsz=640,
    batch=8,
    project="training",
    name="augmentarium"
)
from shutil import copyfile
copyfile(
    "training/augmentarium/weights/best.pt",
    "model.pt"
)

print("Training selesai!")
